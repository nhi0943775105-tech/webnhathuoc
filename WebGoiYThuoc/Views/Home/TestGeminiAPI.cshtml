@{
    ViewData["Title"] = "Test Gemini API";
}

<style>
    .test-container {
        max-width: 1000px;
        margin: 40px auto;
        padding: 20px;
    }
    
    .test-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 20px;
    }
    
    .input-group {
        margin-bottom: 15px;
    }
    
    .input-group label {
        display: block;
        font-weight: 600;
        margin-bottom: 8px;
        color: #1e293b;
    }
    
    .input-group input,
    .input-group textarea,
    .input-group select {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        font-family: monospace;
        font-size: 13px;
    }
    
    .btn-group {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }
    
    button {
        flex: 1;
        padding: 12px 20px;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s;
    }
    
    .btn-test {
        background: #3b82f6;
        color: white;
    }
    
    .btn-test:hover {
        background: #2563eb;
    }
    
    .btn-clear {
        background: #6b7280;
        color: white;
    }
    
    .btn-clear:hover {
        background: #4b5563;
    }
    
    .result-box {
        background: #1e293b;
        color: #e2e8f0;
        padding: 15px;
        border-radius: 6px;
        margin-top: 15px;
        font-family: monospace;
        font-size: 12px;
        max-height: 400px;
        overflow-y: auto;
        white-space: pre-wrap;
        word-break: break-word;
    }
    
    .status-ok {
        color: #10b981;
    }
    
    .status-error {
        color: #ef4444;
    }
    
    .status-warning {
        color: #f59e0b;
    }
    
    .model-info {
        background: #ecfdf5;
        border-left: 4px solid #10b981;
        padding: 12px;
        margin: 10px 0;
        border-radius: 4px;
        font-size: 13px;
    }
    
    .loader {
        display: inline-block;
        width: 16px;
        height: 16px;
        border: 2px solid #cbd5e1;
        border-top-color: #3b82f6;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

<div class="test-container">
    <h1>🧪 Test Gemini API - Debug Tool</h1>
    
    <div class="test-card">
        <h2 style="margin-top: 0;">API Configuration</h2>
        
        <div class="input-group">
            <label for="apiKey">API Key Gemini:</label>
            <input type="password" id="apiKey" placeholder="Nhập API key của bạn (hoặc để trống nếu đã lưu)" />
            <small style="color: #64748b;">Lưu ý: Key sẽ được lưu tạm thời trong session</small>
        </div>
        
        <div class="input-group">
            <label for="selectedModel">Chọn Model:</label>
            <select id="selectedModel">
                <option value="gemini-2.0-flash">gemini-2.0-flash (Mới nhất, nhanh nhất)</option>
                <option value="gemini-1.5-flash">gemini-1.5-flash (Nhanh, độ chính xác cao)</option>
                <option value="gemini-1.5-pro">gemini-1.5-pro (Chính xác cao, chậm hơn)</option>
                <option value="gemini-pro">gemini-pro (Model cổ điển)</option>
            </select>
        </div>
        
        <div class="input-group">
            <label for="testPrompt">Test Prompt:</label>
            <textarea id="testPrompt" rows="4" placeholder="Nhập prompt để test...">Bạn là một dược sĩ. Người bệnh đang bị sốt cao, đau đầu và cảm thấy mệt mỏi. Hãy đưa ra lời khuyên sơ bộ (dưới 50 từ).</textarea>
        </div>
        
        <div class="btn-group">
            <button class="btn-test" onclick="testSingleModel()">
                <span id="testBtnText">Test Model Hiện Tại</span>
            </button>
            <button class="btn-test" onclick="testAllModels()" style="background: #10b981;">Test Tất Cả Models</button>
            <button class="btn-clear" onclick="clearResults()">Xóa Kết Quả</button>
        </div>
    </div>
    
    <div class="test-card">
        <h2 style="margin-top: 0;">Model Information</h2>
        <div class="model-info">
            <strong>gemini-2.0-flash:</strong> Model mới nhất (2024), tốc độ siêu nhanh, giá rẻ, phù hợp cho ứng dụng realtime
        </div>
        <div class="model-info">
            <strong>gemini-1.5-flash:</strong> Nhanh và tiết kiệm chi phí, phù hợp cho trường hợp tổng quát
        </div>
        <div class="model-info">
            <strong>gemini-1.5-pro:</strong> Chính xác cao nhất, xử lý tốt context dài, nhưng chậm và tốn kém hơn
        </div>
        <div class="model-info">
            <strong>gemini-pro:</strong> Model cũ hơn, vẫn hoạt động nhưng không khuyến nghị cho ứng dụng mới
        </div>
    </div>
    
    <div class="test-card">
        <h2 style="margin-top: 0;">Test Results</h2>
        <div id="resultsContainer"></div>
    </div>
</div>

<script>
    const STORAGE_KEY = 'gemini_test_api_key';
    
    function getApiKey() {
        const keyInput = document.getElementById('apiKey').value.trim();
        if (keyInput) {
            sessionStorage.setItem(STORAGE_KEY, keyInput);
            return keyInput;
        }
        return sessionStorage.getItem(STORAGE_KEY) || '';
    }
    
    function saveApiKey(key) {
        sessionStorage.setItem(STORAGE_KEY, key);
        document.getElementById('apiKey').value = key;
    }
    
    async function callGeminiAPI(apiKey, model, prompt) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent?key=${apiKey}`;
        
        const requestBody = {
            contents: [
                {
                    parts: [
                        {
                            text: prompt
                        }
                    ]
                }
            ],
            generationConfig: {
                temperature: 0.7,
                topP: 0.95,
                topK: 40,
                maxOutputTokens: 200
            }
        };
        
        const response = await fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(requestBody)
        });
        
        const data = await response.json();
        return { success: response.ok, status: response.status, data };
    }
    
    async function testSingleModel() {
        const apiKey = getApiKey();
        if (!apiKey) {
            showResult('❌ Lỗi', 'Vui lòng nhập API Key trước!', 'status-error');
            return;
        }
        
        const model = document.getElementById('selectedModel').value;
        const prompt = document.getElementById('testPrompt').value.trim();
        
        if (!prompt) {
            showResult('❌ Lỗi', 'Vui lòng nhập prompt để test!', 'status-error');
            return;
        }
        
        showResult('⏳ Testing', `Đang test model: ${model}...`, 'status-warning');
        
        try {
            const startTime = performance.now();
            const result = await callGeminiAPI(apiKey, model, prompt);
            const endTime = performance.now();
            const duration = (endTime - startTime).toFixed(2);
            
            let resultText = `📊 Model: ${model}\n`;
            resultText += `⏱️  Thời gian: ${duration}ms\n`;
            resultText += `📡 HTTP Status: ${result.status}\n\n`;
            
            if (result.success) {
                resultText += `✅ THÀNH CÔNG!\n\n`;
                
                if (result.data.candidates && result.data.candidates[0]?.content?.parts?.[0]?.text) {
                    resultText += `📝 AI Response:\n`;
                    resultText += `---\n`;
                    resultText += result.data.candidates[0].content.parts[0].text;
                    resultText += `\n---\n`;
                } else {
                    resultText += `⚠️  Phản hồi không có nội dung!\n`;
                    resultText += JSON.stringify(result.data, null, 2);
                }
            } else {
                resultText += `❌ LỖI!\n\n`;
                if (result.data.error) {
                    resultText += `Error Code: ${result.data.error.code}\n`;
                    resultText += `Message: ${result.data.error.message}\n`;
                    if (result.data.error.details) {
                        resultText += `Details:\n${JSON.stringify(result.data.error.details, null, 2)}`;
                    }
                } else {
                    resultText += JSON.stringify(result.data, null, 2);
                }
            }
            
            showResult('Test Result', resultText, result.success ? 'status-ok' : 'status-error');
        } catch (error) {
            showResult('❌ Exception Error', `${error.message}\n\nStack: ${error.stack}`, 'status-error');
        }
    }
    
    async function testAllModels() {
        const apiKey = getApiKey();
        if (!apiKey) {
            showResult('❌ Lỗi', 'Vui lòng nhập API Key trước!', 'status-error');
            return;
        }
        
        const prompt = document.getElementById('testPrompt').value.trim();
        if (!prompt) {
            showResult('❌ Lỗi', 'Vui lòng nhập prompt để test!', 'status-error');
            return;
        }
        
        const models = ['gemini-2.0-flash', 'gemini-1.5-flash', 'gemini-1.5-pro', 'gemini-pro'];
        const container = document.getElementById('resultsContainer');
        container.innerHTML = `<div style="padding: 20px; text-align: center;">⏳ Đang test ${models.length} models...</div>`;
        
        let allResults = `🧪 Test Tất Cả Models\n`;
        allResults += `========================================\n\n`;
        
        for (const model of models) {
            try {
                const startTime = performance.now();
                const result = await callGeminiAPI(apiKey, model, prompt);
                const endTime = performance.now();
                const duration = (endTime - startTime).toFixed(2);
                
                allResults += `📦 Model: ${model}\n`;
                allResults += `⏱️  Time: ${duration}ms\n`;
                allResults += `Status: ${result.success ? '✅ OK' : '❌ FAILED'} (HTTP ${result.status})\n`;
                
                if (result.success && result.data.candidates?.[0]?.content?.parts?.[0]?.text) {
                    const text = result.data.candidates[0].content.parts[0].text.substring(0, 80);
                    allResults += `Preview: ${text}...\n`;
                } else if (!result.success && result.data.error) {
                    allResults += `Error: ${result.data.error.message}\n`;
                }
                
                allResults += `\n`;
                
                // Delay giữa các request để tránh rate limit
                await new Promise(resolve => setTimeout(resolve, 1000));
            } catch (error) {
                allResults += `📦 Model: ${model}\n`;
                allResults += `❌ Exception: ${error.message}\n\n`;
            }
        }
        
        allResults += `========================================\n`;
        allResults += `✨ Test hoàn tất!`;
        
        showResult('All Models Test', allResults, 'status-ok');
    }
    
    function showResult(title, content, statusClass) {
        const container = document.getElementById('resultsContainer');
        container.innerHTML = `
            <div style="margin-bottom: 15px;">
                <strong style="font-size: 16px;">${title}</strong>
            </div>
            <div class="result-box ${statusClass}">
${content}
            </div>
        `;
    }
    
    function clearResults() {
        document.getElementById('resultsContainer').innerHTML = '';
        document.getElementById('testPrompt').value = 'Bạn là một dược sĩ. Người bệnh đang bị sốt cao, đau đầu và cảm thấy mệt mỏi. Hãy đưa ra lời khuyên sơ bộ (dưới 50 từ).';
    }
    
    // Load API key nếu đã lưu trước đó
    window.addEventListener('DOMContentLoaded', () => {
        const savedKey = sessionStorage.getItem(STORAGE_KEY);
        if (savedKey) {
            document.getElementById('apiKey').value = savedKey;
        }
    });
</script>
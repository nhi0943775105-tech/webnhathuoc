@model IEnumerable<WebGoiYThuoc.Models.TrieuChung>
@{
    ViewData["Title"] = "Trang Chủ - MedSuggest";

    var databaseBenhs = ViewBag.Diseases as List<WebGoiYThuoc.Models.Benh> ?? new List<WebGoiYThuoc.Models.Benh>();
    var databaseThuocs = ViewBag.Thuocs as List<WebGoiYThuoc.Models.Thuoc> ?? new List<WebGoiYThuoc.Models.Thuoc>();
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

<style>
    :root {
        --primary: #2563eb;
        --primary-dark: #1d4ed8;
        --primary-light: #dbeafe;
        --secondary: #10b981;
        --secondary-light: #d1fae5;
        --accent: #f59e0b;
        --bg: #f8fafc;
        --surface: #ffffff;
        --text-main: #0f172a;
        --text-secondary: #475569;
        --text-muted: #94a3b8;
        --border: #e2e8f0;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.04);
        --shadow: 0 4px 12px rgba(0,0,0,0.06);
        --shadow-lg: 0 10px 25px rgba(0,0,0,0.08);
        --radius-sm: 8px;
        --radius: 12px;
        --radius-lg: 20px;
        --radius-pill: 100px;
        --font: 'Inter', system-ui, -apple-system, sans-serif;
    }

    body {
        font-family: var(--font);
        background-color: var(--bg);
        color: var(--text-main);
        margin: 0;
        padding: 0;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #2563eb 100%);
        color: white;
        padding: 64px 24px 72px;
        text-align: center;
        position: relative;
        overflow: hidden;
        border-radius: 0 0 40px 40px;
        margin-bottom: 32px;
        box-shadow: var(--shadow-lg);
    }

        .hero-section::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 260px;
            height: 260px;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            border-radius: 50%;
        }

        .hero-section::after {
            content: '';
            position: absolute;
            bottom: -40px;
            left: -40px;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
            border-radius: 50%;
        }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 700px;
        margin: 0 auto;
    }

    .hero-title {
        font-size: 2.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 32px;
        line-height: 1.2;
    }

    .search-container {
        position: relative;
        background: white;
        border-radius: var(--radius-pill);
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        display: flex;
        align-items: center;
        max-width: 640px;
        margin: 0 auto 28px;
        transition: box-shadow 0.2s;
    }

        .search-container:focus-within {
            box-shadow: 0 12px 35px rgba(37, 99, 235, 0.25);
        }

    .search-icon {
        color: var(--text-muted);
        padding-left: 20px;
        font-size: 22px;
    }

    .search-input {
        flex: 1;
        border: none;
        padding: 16px 16px 16px 12px;
        font-size: 1rem;
        outline: none;
        background: transparent;
        color: var(--text-main);
        font-family: var(--font);
    }

        .search-input::placeholder {
            color: #94a3b8;
            font-weight: 400;
        }

    .btn-search {
        background: var(--secondary);
        border: none;
        color: white;
        font-weight: 600;
        padding: 12px 28px;
        margin: 6px 6px 6px 0;
        border-radius: 50px;
        font-size: 0.95rem;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }

        .btn-search:hover {
            background: #059669;
        }

        .btn-search:active {
            transform: scale(0.97);
        }

    .survey-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255,255,255,0.25);
        color: white;
        padding: 10px 24px;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        margin-bottom: 28px;
        transition: background 0.2s;
    }

        .survey-link:hover {
            background: rgba(255,255,255,0.25);
            color: white;
        }

    .popular-tags {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

    .popular-label {
        font-size: 0.875rem;
        color: rgba(255,255,255,0.8);
        font-weight: 500;
        margin-right: 4px;
    }

    .tag-pill {
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        color: white;
        padding: 6px 18px;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s;
        backdrop-filter: blur(4px);
    }

        .tag-pill:hover {
            background: rgba(255,255,255,0.28);
            border-color: rgba(255,255,255,0.5);
        }

    /* Main Layout */
    .main-grid {
        max-width: 1280px;
        margin: 0 auto 40px;
        padding: 0 20px;
        display: flex;
        gap: 32px;
    }

    .content-area {
        flex: 1;
        min-width: 0;
    }

    .sidebar {
        width: 300px;
        flex-shrink: 0;
    }

    /* Card container */
    .card-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 24px;
        box-shadow: var(--shadow-sm);
    }

    /* Tab buttons */
    .tab-header {
        display: flex;
        gap: 4px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 24px;
    }

    .tab-btn {
        background: none;
        border: none;
        padding: 12px 20px;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 6px;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        transition: color 0.2s, border-color 0.2s;
        font-family: var(--font);
    }

        .tab-btn.active-disease {
            color: var(--primary);
            border-bottom-color: var(--primary);
        }

        .tab-btn.active-medicine {
            color: var(--secondary);
            border-bottom-color: var(--secondary);
        }

    /* AI Suggestion */
    .ai-card {
        background: linear-gradient(145deg, #f0fdf4 0%, #ffffff 100%);
        border: 1px solid #a7f3d0;
        border-radius: var(--radius-lg);
        padding: 24px;
        margin-bottom: 24px;
        position: relative;
        box-shadow: var(--shadow);
    }

    .ai-card-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
    }

        .ai-card-header .material-symbols-outlined {
            color: #059669;
            font-size: 24px;
        }

    .ai-card-title {
        font-weight: 700;
        color: #065f46;
        font-size: 1.1rem;
        margin: 0;
    }

    .ai-loading {
        font-size: 0.9rem;
        color: #047857;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .ai-content {
        font-size: 0.92rem;
        color: #334155;
        line-height: 1.6;
    }

    @@keyframes spin {
        100% {
            transform: rotate(360deg);
        }
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .section-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-main);
        margin: 0;
    }

    .section-badge {
        background: #f1f5f9;
        color: #475569;
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    /* Cards Grid */
    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
    }

    /* Disease / Medicine Card */
    .item-card {
        background: white;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
    }

        .item-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        }

    .card-title {
        font-weight: 700;
        color: #1e3a8a;
        font-size: 1.2rem;
        margin: 0 0 8px 0;
    }

    .card-desc {
        color: #475569;
        font-size: 0.9rem;
        line-height: 1.5;
        margin-bottom: 16px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 44px;
    }

    .symptom-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .symptom-badge {
        background: #f1f5f9;
        color: #334155;
        padding: 2px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    /* Medicine specific */
    .medicine-header {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 16px;
    }

    .med-icon {
        background: var(--secondary-light);
        color: #047857;
        border-radius: 10px;
        padding: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .med-name {
        font-weight: 700;
        color: #0f172a;
        font-size: 1.1rem;
        line-height: 1.3;
        margin: 0;
        padding-top: 4px;
    }

    .med-usage {
        color: #475569;
        font-size: 0.88rem;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid #f1f5f9;
        display: flex;
        gap: 8px;
    }

        .med-usage .material-symbols-outlined {
            color: #94a3b8;
            font-size: 18px;
            margin-top: 2px;
        }

    .usage-text {
        font-size: 0.88rem;
    }

    /* Sidebar */
    .sidebar-card {
        background: white;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        position: sticky;
        top: 20px;
        overflow: hidden;
    }

    .sidebar-header {
        background: #f8fafc;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        color: #0f172a;
        font-size: 0.95rem;
    }

    .history-list {
        padding: 8px 0;
    }

    .history-item {
        padding: 12px 20px;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
        transition: background 0.15s;
    }

        .history-item:last-child {
            border-bottom: none;
        }

        .history-item:hover {
            background: #f8fafc;
        }

    .history-time {
        display: flex;
        align-items: center;
        gap: 4px;
        color: #94a3b8;
        font-size: 0.7rem;
        margin-bottom: 4px;
    }

    .history-query {
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
        color: #334155;
        font-size: 0.88rem;
    }

    .empty-history {
        padding: 32px 20px;
        text-align: center;
        color: #94a3b8;
        font-size: 0.85rem;
        font-style: italic;
    }

    /* Responsive */
    @@media (max-width: 992px) {
        .main-grid {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
        }
    }

    @@media (max-width: 768px) {
        .hero-title {
            font-size: 1.8rem;
        }

        .search-container {
            flex-wrap: wrap;
            border-radius: var(--radius);
        }

        .btn-search {
            width: 100%;
            margin: 0 6px 6px 6px;
        }
    }
</style>

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-content">
        <h1 class="hero-title">🩺 Bạn đang cảm thấy thế nào?</h1>

        <div class="search-container">
            <span class="material-symbols-outlined search-icon">search</span>
            <input type="text" id="figmaMainInput" class="search-input" placeholder="Nhập triệu chứng: sốt, đau đầu, ho..." />
            <button type="button" onclick="triggerSearchAction()" class="btn-search">
                <span class="material-symbols-outlined" style="font-size:18px;">search</span> Tìm kiếm
            </button>
        </div>

        <a href="/Home/Survey" class="survey-link">
            <span class="material-symbols-outlined" style="font-size:18px;">description</span>
            Điền phiếu khảo sát chi tiết
        </a>

        <div class="popular-tags">
            <span class="popular-label">Phổ biến:</span>
            <button type="button" onclick="quickTagSearch('Sốt')" class="tag-pill">Sốt</button>
            <button type="button" onclick="quickTagSearch('Đau đầu')" class="tag-pill">Đau đầu</button>
            <button type="button" onclick="quickTagSearch('Mệt mỏi')" class="tag-pill">Mệt mỏi</button>
            <button type="button" onclick="quickTagSearch('Ho khan')" class="tag-pill">Ho khan</button>
            <button type="button" onclick="quickTagSearch('Đau họng')" class="tag-pill">Đau họng</button>
        </div>
    </div>
</section>

<!-- Main Content -->
<div class="main-grid">
    <div class="content-area">
        <div class="card-panel">
            <!-- Tabs -->
            <div class="tab-header">
                <button id="tabDiseaseTrigger" onclick="switchFigmaTab('diseases')" class="tab-btn active-disease">
                    <span class="material-symbols-outlined" style="font-size:18px;">stethoscope</span> Gợi ý Bệnh
                </button>
                <button id="tabMedicineTrigger" onclick="switchFigmaTab('medicines')" class="tab-btn">
                    <span class="material-symbols-outlined" style="font-size:18px;">pill</span> Gợi ý Thuốc
                </button>
            </div>

            <!-- AI Suggestion Card -->
            <div id="aiSuggestionCard" class="ai-card d-none">
                <div class="ai-card-header">
                    <span class="material-symbols-outlined">auto_awesome</span>
                    <h3 class="ai-card-title">AI Trợ lý Y tế MedSuggest</h3>
                </div>
                <div id="aiLoading" class="ai-loading">
                    <span class="material-symbols-outlined" style="font-size:16px; animation: spin 2s linear infinite;">hourglass_empty</span>
                    Đang phân tích và tải lời khuyên từ Google Gemini...
                </div>
                <div id="aiContent" class="ai-content d-none"></div>
            </div>

            <!-- Diseases Panel -->
            <div id="panelDiseaseContainer">
                <div class="section-header">
                    <h2 class="section-title">Bệnh lý có thể gặp phải</h2>
                    <span class="section-badge" id="countDiseaseLabel">@databaseBenhs.Count kết quả</span>
                </div>

                <div class="cards-grid">
                    @foreach (var benh in databaseBenhs)
                    {
                        <div class="item-card disease-search-card" data-name="@benh.TenBenh.ToLower()" data-symptoms="@(benh.TrieuChungs != null ? string.Join(",", benh.TrieuChungs.Select(t => t.TenTrieuChung.ToLower())) : "")">
                            <h3 class="card-title">@benh.TenBenh</h3>
                            <p class="card-desc">@benh.MoTaBenh</p>

                            <div>
                                <p style="font-size:0.7rem; font-weight:600; color:#64748b; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px;">Triệu chứng liên quan</p>
                                <div class="symptom-tags">
                                    @if (benh.TrieuChungs != null && benh.TrieuChungs.Any())
                                    {
                                        foreach (var tc in benh.TrieuChungs)
                                        {
                                            <span class="symptom-badge">@tc.TenTrieuChung</span>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Medicines Panel (hidden by default) -->
            <div id="panelMedicineContainer" class="d-none">
                <div class="section-header">
                    <h2 class="section-title">Các loại thuốc tham khảo</h2>
                    <span class="section-badge" id="countMedicineLabel">@databaseThuocs.Count kết quả</span>
                </div>

                <div class="cards-grid">
                    @foreach (var thuoc in databaseThuocs)
                    {
                        var thuocSymptomList = new List<string>();
                        if (thuoc.Benhs != null)
                        {
                            foreach (var b in thuoc.Benhs)
                            {
                                if (b.TrieuChungs != null)
                                {
                                    thuocSymptomList.AddRange(b.TrieuChungs.Select(t => t.TenTrieuChung.ToLower()));
                                }
                            }
                        }
                        string attributeSymptoms = string.Join(",", thuocSymptomList.Distinct());

                        <div class="item-card medicine-search-card" data-name="@thuoc.TenThuoc.ToLower()" data-symptoms="@attributeSymptoms">
                            <div class="medicine-header">
                                <div class="med-icon">
                                    <span class="material-symbols-outlined">pill</span>
                                </div>
                                <h3 class="med-name">@thuoc.TenThuoc</h3>
                            </div>

                            <div class="med-usage">
                                <span class="material-symbols-outlined">assignment</span>
                                <div class="usage-text">
                                    <strong style="color:#0f172a;">Chỉ định:</strong> @thuoc.CongDung
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar History -->
    <div class="sidebar">
        <div class="sidebar-card">
            <div class="sidebar-header">
                <span class="material-symbols-outlined" style="color:#2563eb;">history</span>
                Lịch sử tìm kiếm gần đây
            </div>
            <div class="history-list" id="figmaHistoryListArea">
                <!-- rendered by JS -->
            </div>
        </div>
    </div>
</div>

<!-- SCRIPTS (giữ nguyên toàn bộ logic) -->
<script>
    // =========================================================================
    // 1. HÀM GỌI API GEMINI
    // =========================================================================
    async function fetchAIAdvice(query) {
        const aiCard = document.getElementById('aiSuggestionCard');
        const aiLoading = document.getElementById('aiLoading');
        const aiContent = document.getElementById('aiContent');

        if (!query || query.trim() === "") {
            aiCard.classList.add('d-none');
            return;
        }

        aiCard.classList.remove('d-none');
        aiLoading.classList.remove('d-none');
        aiLoading.innerHTML = `<span class="material-symbols-outlined" style="font-size: 16px; animation: spin 2s linear infinite;">hourglass_empty</span> Đang phân tích và tải lời khuyên từ Google Gemini...`;
        aiContent.classList.add('d-none');

        const API_KEY = "AQ.Ab8RN6JkUJ_11CPFzQ-DoBj8sPSk6hrzwxhJXXXVoZjtidG04g";

        const promptText = `Bạn là một Dược sĩ tư vấn y tế trực tuyến giàu kinh nghiệm. Người bệnh đang có các triệu chứng sau: [${query}]. Hãy đưa ra một đánh giá sơ bộ ngắn gọn, lời khuyên y tế hữu ích và chế độ chăm sóc sức khỏe tại nhà phù hợp. Yêu cầu: Viết dưới 130 từ, sử dụng định dạng Markdown rõ ràng, thêm các emoji y tế (🩺, 💊, ⚠️) sinh động. Cuối cùng hãy nhắc nhở họ kéo xuống xem danh sách thuốc tham khảo.`;

        const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent?key=${API_KEY}`;

        const requestBody = {
            contents: [
                {
                    parts: [
                        {
                            text: promptText
                        }
                    ]
                }
            ]
        };

        try {
            const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(requestBody)
            });

            if (!response.ok) {
                throw new Error(`Google trả về mã lỗi HTTP: ${response.status}`);
            }

            const data = await response.json();

            if (data && data.candidates && data.candidates.length > 0 &&
                data.candidates[0].content && data.candidates[0].content.parts &&
                data.candidates[0].content.parts.length > 0) {

                const aiResponseText = data.candidates[0].content.parts[0].text;

                aiLoading.classList.add('d-none');

                let formattedAdvice = aiResponseText
                    .replace(/\n/g, '<br>')
                    .replace(/\*\*(.*?)\*\*/g, '<strong style="color: #065f46; font-weight:700;">$1</strong>')
                    .replace(/\*(.*?)\*/g, '<em>$1</em>');

                aiContent.innerHTML = formattedAdvice;
                aiContent.classList.remove('d-none');
            } else {
                aiLoading.innerHTML = `<span class="text-warning" style="display:flex; align-items:center; gap:4px;"><span class="material-symbols-outlined" style="font-size:16px;">shield</span> AI không thể đưa ra đánh giá cho từ khóa này. Vui lòng tham khảo ý kiến bác sĩ trực tiếp.</span>`;
            }

        } catch (error) {
            console.error("Lỗi xử lý AI:", error);
            aiLoading.innerHTML = `<span class="text-danger" style="display:flex; align-items:center; gap:4px;"><span class="material-symbols-outlined" style="font-size:16px;">error</span> Gặp sự cố khi kết nối với trí tuệ nhân tạo (Hạn ngạch hoặc Key hết hạn).</span>`;
        }
    }

    // =========================================================================
    // 2. CHUYỂN TAB
    // =========================================================================
    function switchFigmaTab(target) {
        if (target === 'diseases') {
            document.getElementById('panelDiseaseContainer').classList.remove('d-none');
            document.getElementById('panelMedicineContainer').classList.add('d-none');
            document.getElementById('tabDiseaseTrigger').classList.add('active-disease');
            document.getElementById('tabMedicineTrigger').classList.remove('active-medicine');
        } else {
            document.getElementById('panelDiseaseContainer').classList.add('d-none');
            document.getElementById('panelMedicineContainer').classList.remove('d-none');
            document.getElementById('tabDiseaseTrigger').classList.remove('active-disease');
            document.getElementById('tabMedicineTrigger').classList.add('active-medicine');
        }
    }

    // =========================================================================
    // 3. TÌM KIẾM TRỰC TIẾP
    // =========================================================================
    function runLiveFigmaSearch() {
        const val = document.getElementById('figmaMainInput').value.toLowerCase().trim();

        const diseaseCards = document.querySelectorAll('.disease-search-card');
        let matchedDiseases = 0;
        diseaseCards.forEach(card => {
            const name = card.getAttribute('data-name') || "";
            const symptoms = card.getAttribute('data-symptoms') || "";
            if(name.includes(val) || symptoms.includes(val)) {
                card.style.display = "";
                matchedDiseases++;
            } else {
                card.style.display = "none";
            }
        });
        document.getElementById('countDiseaseLabel').innerText = matchedDiseases + " kết quả";

        const medicineCards = document.querySelectorAll('.medicine-search-card');
        let matchedMedicines = 0;
        medicineCards.forEach(card => {
            const name = card.getAttribute('data-name') || "";
            const symptoms = card.getAttribute('data-symptoms') || "";
            if(name.includes(val) || symptoms.includes(val)) {
                card.style.display = "";
                matchedMedicines++;
            } else {
                card.style.display = "none";
            }
        });
        document.getElementById('countMedicineLabel').innerText = matchedMedicines + " kết quả";
    }

    // =========================================================================
    // 4. XỬ LÝ TÌM KIẾM CHÍNH
    // =========================================================================
    function triggerSearchAction() {
        const inputVal = document.getElementById('figmaMainInput').value.trim();
        if(!inputVal) return;

        runLiveFigmaSearch();
        fetchAIAdvice(inputVal);

        let currentHistory = JSON.parse(localStorage.getItem('med_search_history')) || [];
        currentHistory = currentHistory.filter(h => h.query.toLowerCase() !== inputVal.toLowerCase());
        currentHistory.unshift({ query: inputVal, timestamp: Date.now() });
        if(currentHistory.length > 5) currentHistory.pop();
        localStorage.setItem('med_search_history', JSON.stringify(currentHistory));

        loadHistorySidebarRealtime();
    }

    // =========================================================================
    // 5. LỊCH SỬ
    // =========================================================================
    function getDynamicTimeAgo(timestamp) {
        const diffMs = Date.now() - timestamp;
        const diffMins = Math.floor(diffMs / 60000);
        const diffHours = Math.floor(diffMins / 60);

        if (diffMins < 1) return "Vừa xong";
        if (diffMins < 60) return diffMins + " phút trước";
        if (diffHours < 24) return diffHours + " giờ trước";
        return "Vài ngày trước";
    }

    function loadHistorySidebarRealtime() {
        const area = document.getElementById('figmaHistoryListArea');
        const currentHistory = JSON.parse(localStorage.getItem('med_search_history')) || [];

        if(currentHistory.length === 0) {
            area.innerHTML = `<div class="empty-history">Chưa có lịch sử tìm kiếm</div>`;
            return;
        }

        area.innerHTML = currentHistory.map(h => {
            const timeAgoText = getDynamicTimeAgo(h.timestamp);
            return `
                <div onclick="quickTagSearch('${h.query}')" class="history-item">
                    <div class="history-time">
                        <span class="material-symbols-outlined" style="font-size:11px;">calendar_today</span>
                        <span>${timeAgoText}</span>
                    </div>
                    <div class="history-query">
                        <span class="material-symbols-outlined" style="font-size:16px; color:#94a3b8;">search</span>
                        <span>${h.query}</span>
                    </div>
                </div>
            `;
        }).join('');
    }

    function quickTagSearch(tagText) {
        document.getElementById('figmaMainInput').value = tagText;
        triggerSearchAction();
    }

    // =========================================================================
    // 6. KHỞI TẠO
    // =========================================================================
    document.addEventListener("DOMContentLoaded", function() {
        loadHistorySidebarRealtime();
        setInterval(loadHistorySidebarRealtime, 30000);

        document.getElementById('figmaMainInput').addEventListener("keyup", runLiveFigmaSearch);
        document.getElementById('figmaMainInput').addEventListener("keydown", function(e) {
            if(e.key === "Enter") {
                triggerSearchAction();
            }
        });

        var initialQuery = "@Html.Raw(ViewBag.InitialSearchQuery)";
        if (initialQuery && initialQuery.trim() !== "") {
            document.getElementById('figmaMainInput').value = initialQuery;
            setTimeout(function() {
                triggerSearchAction();
            }, 300);
        }
    });
</script>
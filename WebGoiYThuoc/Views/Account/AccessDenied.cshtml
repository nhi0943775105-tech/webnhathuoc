@{
    Layout = null; // Giữ nguyên để chạy độc lập, không bị ảnh hưởng layout chung
    ViewData["Title"] = "Truy cập bị từ chối";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MedSuggest</title>

    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --font: 'Inter', system-ui, -apple-system, sans-serif;
        }

        body {
            font-family: var(--font);
            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 50%, #ffffff 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }

        .denied-card {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.06), 0 8px 16px rgba(0,0,0,0.03);
            padding: 48px 40px;
            text-align: center;
            max-width: 520px;
            width: 100%;
            animation: fadeIn 0.4s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .denied-icon {
            font-size: 80px;
            color: #ef4444;
            margin-bottom: 16px;
            display: inline-block;
            background: #fee2e2;
            border-radius: 50%;
            padding: 24px;
            width: 100px;
            height: 100px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: auto;
            margin-right: auto;
        }

            .denied-icon .material-symbols-outlined {
                font-size: 52px;
            }

        .denied-title {
            font-size: 2rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 16px;
            letter-spacing: -0.3px;
        }

        .denied-message {
            font-size: 1rem;
            color: #475569;
            line-height: 1.6;
            margin-bottom: 32px;
        }

            .denied-message b {
                color: #b92525;
                font-weight: 600;
            }

        .btn-home {
            background: #2d68e7;
            border: none;
            color: white;
            font-weight: 600;
            padding: 14px 28px;
            border-radius: 12px;
            font-size: 1rem;
            text-decoration: none;
            
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background 0.2s, transform 0.1s;
            box-shadow: 0 4px 10px rgba(35, 94, 220, 0.3);
        }

            .btn-home:hover {
                background: #2353d8;
                color: white;
                transform: translateY(-1px);
            }

            .btn-home:active {
                transform: scale(0.98);
            }
    </style>
</head>
<body>
    <div class="denied-card">
        <div class="denied-icon">
            <span class="material-symbols-outlined">gavel</span>
        </div>
        <h1 class="denied-title">Quyền truy cập bị từ chối</h1>
        <p class="denied-message">
            Tài khoản của bạn không có đặc quyền của <b>Quản trị viên (Admin)</b> để vào khu vực này.<br />
            Vui lòng liên hệ quản trị hệ thống nếu bạn cần quyền truy cập.
        </p>
        <a href="/" class="btn-home">
            <span class="material-symbols-outlined" style="font-size:20px;">home</span>
            Về Trang chủ
        </a>
    </div>
</body>
</html>
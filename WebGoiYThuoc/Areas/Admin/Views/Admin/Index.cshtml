                </div>
            </div>
        </div>
    </div>

    <!-- ========== MODAL SỬA TRIỆU CHỨNG ========== -->
    <div class="modal fade" id="editTrieuChungModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                <div class="modal-header border-0" style="background: #f8fafc; border-radius: 16px 16px 0 0;">
                    <h5 class="modal-title fw-bold" style="color: #1e3a8a;">
                        <span class="material-symbols-outlined" style="vertical-align: middle;">edit</span> Sửa Triệu Chứng
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editTcId" />
                    <div class="mb-3">
                        <label class="form-label">Tên triệu chứng</label>
                        <input type="text" id="editTenTrieuChung" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea id="editMoTa" class="form-control" rows="4"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-emerald" onclick="submitEditTrieuChung()">Lưu thay đổi</button>
                </div>
            </div>
        </div>
    </div>


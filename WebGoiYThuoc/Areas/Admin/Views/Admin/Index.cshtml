@model IEnumerable<WebGoiYThuoc.Models.Benh>
@{
    Layout = null;
    var thuocs = ViewBag.Thuocs as List<WebGoiYThuoc.Models.Thuoc>;
    var trieuChungs = ViewBag.TrieuChungs as List<WebGoiYThuoc.Models.TrieuChung>;
    var currentUsername = User.Identity?.Name ?? "Admin";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản trị - MedSuggest</title>

    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --secondary: #10b981;
            --secondary-dark: #059669;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --bg-light: #f8fafc;
            --radius: 16px;
            --radius-sm: 10px;
            --shadow: 0 4px 12px rgba(0,0,0,0.04);
            --font: 'Inter', system-ui, -apple-system, sans-serif;
        }

        body {
            font-family: var(--font);
            background: var(--bg-light);
            color: var(--text-main);
            margin: 0;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 280px;
            background: linear-gradient(180deg, #0f172a 0%, #1e3a8a 100%);
            color: white;
            display: flex;
            flex-direction: column;
            padding: 28px 16px;
            box-shadow: 4px 0 20px rgba(0,0,0,0.08);
            flex-shrink: 0;
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            padding-bottom: 24px;
            margin-bottom: 24px;
            border-bottom: 1px solid rgba(255,255,255,0.12);
            text-decoration: none;
            color: white;
        }

            .sidebar-logo:hover {
                color: white;
            }

            .sidebar-logo .logo-icon {
                font-size: 28px;
                color: #60a5fa;
            }

            .sidebar-logo .logo-text {
                font-size: 1.3rem;
                font-weight: 700;
                letter-spacing: -0.3px;
            }

            .sidebar-logo .logo-sub {
                font-size: 0.65rem;
                font-weight: 500;
                color: #93c5fd;
                text-transform: uppercase;
                letter-spacing: 1px;
                display: block;
            }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            color: #bfdbfe;
            font-weight: 500;
            font-size: 0.9rem;
            text-decoration: none;
            margin-bottom: 4px;
            transition: background 0.2s, color 0.2s;
            cursor: pointer;
        }

            .nav-link:hover {
                background: rgba(255,255,255,0.12);
                color: white;
            }

            .nav-link.active {
                background: rgba(255,255,255,0.18);
                color: white;
                font-weight: 600;
                box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            }

            .nav-link .material-symbols-outlined {
                font-size: 20px;
            }

        /* Main */
        .main-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .top-header {
            background: white;
            border-bottom: 1px solid var(--border);
            padding: 16px 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 1px 6px rgba(0,0,0,0.02);
        }

        .page-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #1e3a8a;
            margin: 0;
        }

        .user-area {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .user-info {
            text-align: right;
            font-size: 0.8rem;
            color: #64748b;
        }

            .user-info strong {
                font-size: 0.9rem;
                color: #0f172a;
                display: block;
            }

        .btn-home {
            border: 1px solid var(--border);
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 500;
            font-size: 0.85rem;
            background: white;
            color: #475569;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: background 0.2s;
        }

            .btn-home:hover {
                background: #f1f5f9;
                color: #1e3a8a;
            }

        /* Content */
        .content-body {
            padding: 28px;
            flex: 1;
        }

        .card-custom {
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 24px;
            height: 100%;
        }

        .form-label {
            font-weight: 600;
            color: #334155;
            font-size: 0.8rem;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 6px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .form-control {
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 10px 14px;
            font-size: 0.9rem;
            background: #f8fafc;
            transition: 0.2s;
            font-family: var(--font);
        }

            .form-control:focus {
                border-color: var(--secondary);
                box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
                background: white;
            }

        .btn-emerald {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            border: none;
            color: white;
            font-weight: 600;
            padding: 10px 20px;
            border-radius: var(--radius-sm);
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            box-shadow: 0 4px 10px rgba(16, 185, 129, 0.25);
        }

            .btn-emerald:hover {
                background: linear-gradient(135deg, #059669 0%, #047857 100%);
                box-shadow: 0 6px 14px rgba(16, 185, 129, 0.35);
                color: white;
            }

        .table-custom th {
            background: #f8fafc;
            color: #64748b;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 0.8px;
            padding: 14px;
            border-bottom: 2px solid #e2e8f0;
        }

        .table-custom td {
            padding: 14px;
            font-size: 0.9rem;
            border-bottom: 1px solid #e2e8f0;
            vertical-align: middle;
        }

        .badge-id {
            background: #f1f5f9;
            color: #334155;
            font-family: monospace;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* Link tab specific */
        .selectable-card {
            border: 2px solid #e2e8f0;
            border-radius: var(--radius-sm);
            padding: 12px 14px;
            background: white;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
        }

            .selectable-card:hover {
                border-color: #cbd5e1;
                background: #f8fafc;
            }

        .card-radio-input:checked + .selectable-card {
            border-color: var(--primary);
            background: #eff6ff;
            box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.2);
        }

        .card-checkbox-input:checked + .selectable-card {
            border-color: var(--secondary);
            background: #ecfdf5;
            box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2);
        }

        .card-radio-input:checked + .selectable-card .card-icon-box {
            background: var(--primary);
            color: white;
        }

        .card-checkbox-input:checked + .selectable-card .card-icon-box {
            background: var(--secondary);
            color: white;
        }

        .card-icon-box {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            transition: 0.2s;
            flex-shrink: 0;
        }

        .card-radio-input, .card-checkbox-input {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }

        /* Responsive */
        @@media (max-width: 992px) {
            body {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                flex-direction: row;
                flex-wrap: wrap;
                padding: 16px;
            }

                .sidebar .nav-link {
                    width: auto;
                    margin-right: 8px;
                }
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <a href="/" class="sidebar-logo">
            <span class="material-symbols-outlined logo-icon">medical_services</span>
            <div>
                <span class="logo-text">MedSuggest</span>
                <span class="logo-sub">Admin Panel</span>
            </div>
        </a>

        <nav class="nav flex-column w-100">
            <a class="nav-link active" id="btn-benh" onclick="switchTab('tab-benh', 'btn-benh')">
                <span class="material-symbols-outlined">stethoscope</span> Quản lý Bệnh
            </a>
            <a class="nav-link" id="btn-thuoc" onclick="switchTab('tab-thuoc', 'btn-thuoc')">
                <span class="material-symbols-outlined">pill</span> Quản lý Thuốc
            </a>
            <a class="nav-link" id="btn-trieuchung" onclick="switchTab('tab-trieuchung', 'btn-trieuchung')">
                <span class="material-symbols-outlined">sick</span> Quản lý Triệu Chứng
            </a>
            <a class="nav-link" id="btn-lienket" onclick="switchTab('tab-lienket', 'btn-lienket')">
                <span class="material-symbols-outlined">link</span> Liên Kết Dữ Liệu
            </a>
        </nav>
    </div>

    <!-- Main Area -->
    <div class="main-area">
        <div class="top-header">
            <h1 class="page-title" id="txt-current-title">Quản lý Bệnh Lý</h1>
            <div class="user-area">
                <div class="user-info">
                    <span>Quản trị viên</span>
                    <strong>@currentUsername</strong>
                </div>
                <a href="/" class="btn-home">
                    <span class="material-symbols-outlined" style="font-size:18px;">home</span> Trang chủ
                </a>
            </div>
        </div>

        <div class="content-body">

            <!-- Tab Benh -->
            <div class="admin-tab" id="tab-benh">
                <div class="row g-4">
                    <div class="col-lg-4">
                        <div class="card-custom">
                            <h5 class="fw-bold mb-3" style="color:#1e3a8a;"><span class="material-symbols-outlined" style="vertical-align: middle;">add_circle</span> Thêm Bệnh Lý</h5>
                            <form asp-area="Admin" asp-controller="Admin" asp-action="AddBenh" method="POST">
                                <div class="mb-3">
                                    <label class="form-label">Tên bệnh</label>
                                    <input type="text" name="TenBenh" class="form-control" required placeholder="Ví dụ: Cảm cúm, Viêm xoang..." />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Mô tả</label>
                                    <textarea name="MoTaBenh" class="form-control" rows="3" placeholder="Mô tả biểu hiện bệnh..."></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Lời khuyên</label>
                                    <textarea name="LoiKhuyen" class="form-control" rows="3" placeholder="Chế độ chăm sóc, dinh dưỡng..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-emerald w-100"><span class="material-symbols-outlined" style="font-size:18px;">save</span> Lưu bệnh</button>
                            </form>
                        </div>
                    </div>
                    <div class="col-lg-8">
                        <div class="card-custom">
                            <h5 class="fw-bold mb-3" style="color:#1e3a8a;">Danh sách Bệnh</h5>
                            <div class="table-responsive">
                                <table class="table table-hover table-custom m-0">
                                    <thead><tr><th>Mã</th><th>Tên Bệnh</th><th>Mô tả</th></tr></thead>
                                    <tbody>
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td><span class="badge-id">#@item.Id</span></td>
                                                <td><strong>@item.TenBenh</strong></td>
                                                <td class="text-muted">@item.MoTaBenh</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Thuoc -->
            <div class="admin-tab d-none" id="tab-thuoc">
                <div class="row g-4">
                    <div class="col-lg-4">
                        <div class="card-custom">
                            <h5 class="fw-bold mb-3" style="color:#1e3a8a;"><span class="material-symbols-outlined" style="vertical-align: middle;">add_circle</span> Thêm Thuốc</h5>
                            <form asp-area="Admin" asp-controller="Admin" asp-action="AddThuoc" method="POST">
                                <div class="mb-3">
                                    <label class="form-label">Tên thuốc</label>
                                    <input type="text" name="TenThuoc" class="form-control" required placeholder="Paracetamol..." />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Công dụng</label>
                                    <textarea name="CongDung" class="form-control" rows="6" placeholder="Chỉ định, liều dùng..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-emerald w-100"><span class="material-symbols-outlined" style="font-size:18px;">save</span> Lưu thuốc</button>
                            </form>
                        </div>
                    </div>
                    <div class="col-lg-8">
                        <div class="card-custom">
                            <h5 class="fw-bold mb-3" style="color:#1e3a8a;">Danh mục Thuốc</h5>
                            <div class="table-responsive">
                                <table class="table table-hover table-custom m-0">
                                    <thead><tr><th>Mã</th><th>Tên Thuốc</th><th>Công dụng</th></tr></thead>
                                    <tbody>
                                        @if (thuocs != null)
                                        {
                                            foreach (var item in thuocs)
                                            {
                                                <tr>
                                                    <td><span class="badge-id">#@item.Id</span></td>
                                                    <td><strong class="text-success">@item.TenThuoc</strong></td>
                                                    <td class="text-muted">@item.CongDung</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Trieu Chung -->
            <div class="admin-tab d-none" id="tab-trieuchung">
                <div class="row g-4">
                    <div class="col-lg-4">
                        <div class="card-custom">
                            <h5 class="fw-bold mb-3" style="color:#1e3a8a;"><span class="material-symbols-outlined" style="vertical-align: middle;">add_circle</span> Thêm Triệu Chứng</h5>
                            <form asp-area="Admin" asp-controller="Admin" asp-action="AddTrieuChung" method="POST">
                                <div class="mb-3">
                                    <label class="form-label">Tên triệu chứng</label>
                                    <input type="text" name="TenTrieuChung" class="form-control" required placeholder="Sốt cao, Ho khan..." />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Mô tả</label>
                                    <textarea name="MoTa" class="form-control" rows="6" placeholder="Biểu hiện chi tiết..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-emerald w-100"><span class="material-symbols-outlined" style="font-size:18px;">save</span> Lưu triệu chứng</button>
                            </form>
                        </div>
                    </div>
                    <div class="col-lg-8">
                        <div class="card-custom">
                            <h5 class="fw-bold mb-3" style="color:#1e3a8a;">Từ điển Triệu Chứng</h5>
                            <div class="table-responsive">
                                <table class="table table-hover table-custom m-0">
                                    <thead><tr><th>Mã</th><th>Tên Triệu Chứng</th><th>Mô tả</th></tr></thead>
                                    <tbody>
                                        @if (trieuChungs != null)
                                        {
                                            foreach (var item in trieuChungs)
                                            {
                                                <tr>
                                                    <td><span class="badge-id">#@item.Id</span></td>
                                                    <td><strong class="text-warning">@item.TenTrieuChung</strong></td>
                                                    <td class="text-muted">@item.MoTa</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Lien Ket -->
            <div class="admin-tab d-none" id="tab-lienket">
                <div class="card-custom mb-4">
                    <h5 class="fw-bold mb-4" style="color:#1e3a8a;">Thiết lập Liên kết Bệnh - Triệu chứng - Thuốc</h5>

                    <form asp-area="Admin" asp-controller="Admin" asp-action="LinkBenhDetail" method="POST">
                        <div class="row g-4">
                            <div class="col-lg-4">
                                <label class="form-label mb-3">1. Chọn Bệnh</label>
                                <div style="max-height:350px; overflow-y:auto;">
                                    @foreach (var b in Model)
                                    {
                                        <label class="d-block position-relative">
                                            <input type="radio" name="benhId" value="@b.Id" class="card-radio-input" required />
                                            <div class="selectable-card">
                                                <div class="card-icon-box"><span class="material-symbols-outlined">stethoscope</span></div>
                                                <div>
                                                    <div class="fw-bold">@b.TenBenh</div>
                                                    <small class="text-muted">Mã #@b.Id</small>
                                                </div>
                                            </div>
                                        </label>
                                    }
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <label class="form-label mb-3">2. Chọn Triệu Chứng</label>
                                <div style="max-height:350px; overflow-y:auto;">
                                    @if (trieuChungs != null)
                                    {
                                        foreach (var tc in trieuChungs)
                                        {
                                            <label class="d-block position-relative">
                                                <input type="checkbox" name="selectedTrieuChungs" value="@tc.Id" class="card-checkbox-input" />
                                                <div class="selectable-card">
                                                    <div class="card-icon-box"><span class="material-symbols-outlined">sick</span></div>
                                                    <div>
                                                        <div class="fw-bold">@tc.TenTrieuChung</div>
                                                        <small class="text-muted">ID @tc.Id</small>
                                                    </div>
                                                </div>
                                            </label>
                                        }
                                    }
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <label class="form-label mb-3">3. Chọn Thuốc</label>
                                <div style="max-height:350px; overflow-y:auto;">
                                    @if (thuocs != null)
                                    {
                                        foreach (var th in thuocs)
                                        {
                                            <label class="d-block position-relative">
                                                <input type="checkbox" name="selectedThuocs" value="@th.Id" class="card-checkbox-input" />
                                                <div class="selectable-card">
                                                    <div class="card-icon-box"><span class="material-symbols-outlined">pill</span></div>
                                                    <div>
                                                        <div class="fw-bold text-success">@th.TenThuoc</div>
                                                        <small class="text-muted">ID @th.Id</small>
                                                    </div>
                                                </div>
                                            </label>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="text-end mt-4">
                            <button type="submit" class="btn btn-emerald px-5">Lưu Liên Kết</button>
                        </div>
                    </form>
                </div>

                <!-- Bảng tổng hợp -->
                <div class="card-custom">
                    <h5 class="fw-bold mb-3">Bản đồ Dữ liệu Đã Liên kết</h5>
                    <div class="table-responsive">
                        <table class="table table-custom m-0">
                            <thead class="text-white" style="background:#1e3a8a;">
                                <tr><th>Bệnh</th><th>Triệu chứng</th><th>Thuốc gợi ý</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><strong>@item.TenBenh</strong></td>
                                        <td>
                                            @if (item.TrieuChungs != null && item.TrieuChungs.Any())
                                            {
                                                foreach (var tc in item.TrieuChungs)
                                                {
                                                    <span class="badge bg-warning text-dark me-1">@tc.TenTrieuChung</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">Chưa có</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.Thuocs != null && item.Thuocs.Any())
                                            {
                                                foreach (var th in item.Thuocs)
                                                {
                                                    <span class="badge bg-success me-1">@th.TenThuoc</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">Chưa có</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function switchTab(tabId, btnId) {
            document.querySelectorAll('.admin-tab').forEach(tab => tab.classList.add('d-none'));
            document.querySelectorAll('.nav-link').forEach(btn => btn.classList.remove('active'));

            document.getElementById(tabId).classList.remove('d-none');
            document.getElementById(btnId).classList.add('active');

            var titleMap = {
                'btn-benh': 'Quản lý Bệnh Lý',
                'btn-thuoc': 'Quản lý Thuốc',
                'btn-trieuchung': 'Quản lý Triệu Chứng',
                'btn-lienket': 'Liên Kết Dữ Liệu'
            };
            document.getElementById('txt-current-title').innerText = titleMap[btnId] || 'Quản trị';
        }

        document.addEventListener("DOMContentLoaded", function () {
            var activeTabFromBackend = "@ViewBag.ActiveTab";
            if (activeTabFromBackend === "tab-lienket") {
                switchTab('tab-lienket', 'btn-lienket');
            } else if (activeTabFromBackend === "tab-thuoc") {
                switchTab('tab-thuoc', 'btn-thuoc');
            } else if (activeTabFromBackend === "tab-trieuchung") {
                switchTab('tab-trieuchung', 'btn-trieuchung');
            } else {
                switchTab('tab-benh', 'btn-benh');
            }
        });
    </script>
</body>
</html>
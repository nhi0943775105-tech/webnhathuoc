    <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                <div class="modal-header border-0" style="background: #fef2f2; border-radius: 16px 16px 0 0;">
                    <h5 class="modal-title fw-bold" style="color: #b91c1c;">
                        <span class="material-symbols-outlined" style="vertical-align: middle;">delete_forever</span> Xác nhận xóa
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <p>Bạn có chắc muốn xóa triệu chứng <strong id="deleteTcName" class="text-danger"></strong>?</p>
                    <p class="text-muted small">Hành động này không thể hoàn tác.</p>
                    <input type="hidden" id="deleteTcId" />
                </div>
                <div class="modal-footer border-0 justify-content-center">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-danger" onclick="executeDeleteTrieuChung()">Xóa vĩnh viễn</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ========== CHUYỂN TAB ==========
        function switchTab(tabId, btnId) {
            document.querySelectorAll('.admin-tab').forEach(tab => tab.classList.add('d-none'));
            document.querySelectorAll('.nav-link').forEach(btn => btn.classList.remove('active'));
            document.getElementById(tabId).classList.remove('d-none');
            document.getElementById(btnId).classList.add('active');
            var titleMap = {
                'btn-benh': 'Quản lý Bệnh Lý',
                'btn-thuoc': 'Quản lý Thuốc',
                'btn-trieuchung': 'Quản lý Triệu Chứng',
                'btn-lienket': 'Liên Kết Dữ Liệu'
            };
            document.getElementById('txt-current-title').innerText = titleMap[btnId] || 'Quản trị';
        }

        // ========== CÁC HÀM CHO BỆNH ==========
        async function editBenh(id) {
            try {
                const response = await fetch(`/Admin/Admin/GetBenh?id=${id}`);
                if (!response.ok) throw new Error('Không tìm thấy bệnh.');
                const data = await response.json();
                document.getElementById('editBenhId').value = id;
                document.getElementById('editTenBenh').value = data.tenBenh || '';
                document.getElementById('editMoTaBenh').value = data.moTaBenh || '';
                document.getElementById('editLoiKhuyen').value = data.loiKhuyen || '';
                const modal = new bootstrap.Modal(document.getElementById('editBenhModal'));
                modal.show();
            } catch (err) {
                alert('Lỗi: ' + err.message);
            }
        }

        async function submitEditBenh() {
            const id = document.getElementById('editBenhId').value;
            const ten = document.getElementById('editTenBenh').value.trim();
            const mota = document.getElementById('editMoTaBenh').value.trim();
            const loiKhuyen = document.getElementById('editLoiKhuyen').value.trim();
            if (!ten) {
                alert('Tên bệnh không được để trống.');
                return;
            }
            try {
                const formData = new FormData();
                formData.append('TenBenh', ten);
                formData.append('MoTaBenh', mota);
                formData.append('LoiKhuyen', loiKhuyen);
                const response = await fetch(`/Admin/Admin/UpdateBenh?id=${id}`, {
                    method: 'POST',
                    body: formData
                });
                if (!response.ok) {
                    const errText = await response.text();
                    throw new Error(errText || 'Cập nhật thất bại.');
                }
                bootstrap.Modal.getInstance(document.getElementById('editBenhModal')).hide();
                window.location.href = '/Admin/Admin?activeTab=tab-benh';
            } catch (err) {
                alert('Lỗi: ' + err.message);
            }
        }

        function confirmDeleteBenh(id, name) {
            document.getElementById('deleteBenhId').value = id;
            document.getElementById('deleteBenhName').innerText = name;
            const modal = new bootstrap.Modal(document.getElementById('deleteBenhConfirmModal'));
            modal.show();
        }

        async function executeDeleteBenh() {
            const id = document.getElementById('deleteBenhId').value;
            try {
                const response = await fetch(`/Admin/Admin/DeleteBenh?id=${id}`, {
                    method: 'POST'
                });
                if (!response.ok) {
                    const errText = await response.text();
                    throw new Error(errText || 'Xóa thất bại.');
                }
                bootstrap.Modal.getInstance(document.getElementById('deleteBenhConfirmModal')).hide();
                window.location.href = '/Admin/Admin?activeTab=tab-benh';
            } catch (err) {
                alert('Lỗi: ' + err.message);
            }
        }

        // ========== CÁC HÀM CHO THUỐC ==========
        async function editThuoc(id) {
            try {
                const response = await fetch(`/Admin/Admin/GetThuoc?id=${id}`);
                if (!response.ok) throw new Error('Không tìm thấy thuốc.');
                const data = await response.json();
                document.getElementById('editThuocId').value = id;
                document.getElementById('editTenThuoc').value = data.tenThuoc || '';
                document.getElementById('editCongDung').value = data.congDung || '';
                const modal = new bootstrap.Modal(document.getElementById('editThuocModal'));
                modal.show();
            } catch (err) {
                alert('Lỗi: ' + err.message);
            }
        }

        async function submitEditThuoc() {
            const id = document.getElementById('editThuocId').value;
            const ten = document.getElementById('editTenThuoc').value.trim();
            const congDung = document.getElementById('editCongDung').value.trim();
            if (!ten) {
                alert('Tên thuốc không được để trống.');
                return;
            }
            try {
                const formData = new FormData();
                formData.append('TenThuoc', ten);
                formData.append('CongDung', congDung);
                const response = await fetch(`/Admin/Admin/UpdateThuoc?id=${id}`, {
                    method: 'POST',
                    body: formData
                });
                if (!response.ok) {
                    const errText = await response.text();
                    throw new Error(errText || 'Cập nhật thất bại.');
                }
                bootstrap.Modal.getInstance(document.getElementById('editThuocModal')).hide();
                window.location.href = '/Admin/Admin?activeTab=tab-thuoc';
            } catch (err) {
                alert('Lỗi: ' + err.message);
            }
        }

        function confirmDeleteThuoc(id, name) {
            document.getElementById('deleteThuocId').value = id;
            document.getElementById('deleteThuocName').innerText = name;
            const modal = new bootstrap.Modal(document.getElementById('deleteThuocConfirmModal'));
            modal.show();
        }

        async function executeDeleteThuoc() {
            const id = document.getElementById('deleteThuocId').value;
            try {
                const response = await fetch(`/Admin/Admin/DeleteThuoc?id=${id}`, {
                    method: 'POST'
                });
                if (!response.ok) {
                    const errText = await response.text();
                    throw new Error(errText || 'Xóa thất bại.');
                }
                bootstrap.Modal.getInstance(document.getElementById('deleteThuocConfirmModal')).hide();
                window.location.href = '/Admin/Admin?activeTab=tab-thuoc';
            } catch (err) {
                alert('Lỗi: ' + err.message);
            }
        }

        // ========== CÁC HÀM CHO TRIỆU CHỨNG ==========
        async function editTrieuChung(id) {
            try {
                const response = await fetch(`/Admin/Admin/GetTrieuChung?id=${id}`);
                if (!response.ok) throw new Error('Không tìm thấy triệu chứng.');
                const data = await response.json();
                document.getElementById('editTcId').value = id;
                document.getElementById('editTenTrieuChung').value = data.tenTrieuChung || '';
                document.getElementById('editMoTa').value = data.moTa || '';
                const modal = new bootstrap.Modal(document.getElementById('editTrieuChungModal'));
                modal.show();
            } catch (err) {
                alert('Lỗi: ' + err.message);
            }
        }

        async function submitEditTrieuChung() {
            const id = document.getElementById('editTcId').value;
            const ten = document.getElementById('editTenTrieuChung').value.trim();
            const mota = document.getElementById('editMoTa').value.trim();
            if (!ten) {
                alert('Tên triệu chứng không được để trống.');
                return;
            }
            try {
                const formData = new FormData();
                formData.append('TenTrieuChung', ten);
                formData.append('MoTa', mota);
                const response = await fetch(`/Admin/Admin/UpdateTrieuChung?id=${id}`, {
                    method: 'POST',
                    body: formData
                });
                if (!response.ok) {
                    const errText = await response.text();
                    throw new Error(errText || 'Cập nhật thất bại.');
                }
                bootstrap.Modal.getInstance(document.getElementById('editTrieuChungModal')).hide();
                window.location.href = '/Admin/Admin?activeTab=tab-trieuchung';
            } catch (err) {
                alert('Lỗi: ' + err.message);
            }
        }

        function confirmDeleteTrieuChung(id, name) {
            document.getElementById('deleteTcId').value = id;
            document.getElementById('deleteTcName').innerText = name;
            const modal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
            modal.show();
        }

        async function executeDeleteTrieuChung() {
            const id = document.getElementById('deleteTcId').value;
            try {
                const response = await fetch(`/Admin/Admin/DeleteTrieuChung?id=${id}`, {
                    method: 'POST'
                });
                if (!response.ok) {
                    const errText = await response.text();
                    throw new Error(errText || 'Xóa thất bại.');
                }
                bootstrap.Modal.getInstance(document.getElementById('deleteConfirmModal')).hide();
                window.location.href = '/Admin/Admin?activeTab=tab-trieuchung';
            } catch (err) {
                alert('Lỗi: ' + err.message);
            }
        }

        // ========== KHỞI TẠO TAB ==========
        document.addEventListener("DOMContentLoaded", function () {
            var activeTabFromBackend = "@ViewBag.ActiveTab";
            if (activeTabFromBackend === "tab-lienket") {
                switchTab('tab-lienket', 'btn-lienket');
            } else if (activeTabFromBackend === "tab-thuoc") {
                switchTab('tab-thuoc', 'btn-thuoc');
            } else if (activeTabFromBackend === "tab-trieuchung") {
                switchTab('tab-trieuchung', 'btn-trieuchung');
            } else {
                switchTab('tab-benh', 'btn-benh');
            }
        });
    </script>
</body>
</html>